# AzureLens — example environment variables for local development.
#
# Copy to `.env` (which is gitignored). NEVER put real secrets in this file
# or in `.env`. In Azure environments secrets are resolved at runtime via
# Managed Identity from Azure Key Vault — see docs/SECURITY_MODEL.md § 5.

# ---- Frontend (apps/frontend) ------------------------------------------
# PUBLIC; baked into the Next.js build. Browser-visible.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- Backend API (apps/api) --------------------------------------------
# Top-level environment selector. Demo mode runs as `local`; anything else
# is treated as a deployed environment and disables permissive CORS.
AZURELENS_ENV=local

# Reserved for Phase 1 (not used in demo mode). Resource URIs are not
# secrets — only the values they reference (resolved via Managed Identity).
# Uncomment as the corresponding Azure resources come online.
#
# AZURELENS_ENTRA_TENANT_ID=
# AZURELENS_ENTRA_AUDIENCE=api://azurelens-api
# AZURELENS_KEYVAULT_URI=https://<your-kv>.vault.azure.net/
# AZURELENS_COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
# AZURELENS_SERVICEBUS_FQNS=<your-namespace>.servicebus.windows.net
# AZURELENS_APPINSIGHTS_CONNECTION_STRING=

# ---- docker-compose port overrides -------------------------------------
# Only set these if you change the host port mappings in docker-compose.yml.
# API_HOST_PORT=8000
# FRONTEND_HOST_PORT=3000
