# AzureLens API — Docker build context exclusions.

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
.eggs

# Virtual environments
.venv
venv
env

# Local config / secrets — must never be baked into images.
.env
.env.*

# Test / lint / type caches
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
.coverage.*
htmlcov

# Docs / VCS / IDE noise
*.log
*.md
.git
.gitignore
.github
.idea
.vscode
tests
dist
build
