# AzureLens API — Docker build context exclusions.

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
.eggs

# Virtual environments
.venv
venv
env

# Local config / secrets — must never be baked into images.
.env
.env.*

# Test / lint / type caches
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
.coverage.*
htmlcov

# Docs / VCS / IDE noise
*.log
.git
.gitignore
.github
.idea
.vscode
tests
dist
build

# IMPORTANT: README.md MUST be in the build context — pyproject.toml has
# `readme = "README.md"`, so `pip install .` (run inside the builder stage
# of apps/api/Dockerfile) fails with a hatchling error if the file is
# missing. Keep this explicit allow even if future patterns above would
# already permit it; it documents the contract and survives later edits
# (e.g. a global `*.md` exclusion).
!README.md
